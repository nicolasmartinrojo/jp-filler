{
  "manifest_version": 3,
  "name": "JP Filler",
  "version": "1.1.0",
  "description": "Auto-fill job application forms with your saved profile.",
  "action": {
    "default_popup": "index.html",
    "default_title": "JP Filler",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["activeTab", "scripting", "storage"]
}
